# Database
DATABASE_URL=postgresql://suds:suds_dev_password@localhost:5433/suds_v2

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# OAuth Providers — set up apps at each provider's developer console
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Anthropic — AI-powered NPC dialogue and lore generation
ANTHROPIC_API_KEY=

# Admin — comma-separated emails that get admin access
ADMIN_EMAILS=you@example.com

# Dev mode (set to "true" for local dev credentials login)
# NEXT_PUBLIC_DEV_MODE=true
